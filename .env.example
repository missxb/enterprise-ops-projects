# 企业级运维项目集 - 环境变量模板
# 复制为 .env 并填入实际值: cp .env.example .env
# ⚠️  请勿将 .env 文件提交到版本控制

# ============================================================
# 通用配置
# ============================================================
ENVIRONMENT=production
LOG_LEVEL=info

# ============================================================
# Kubernetes (scripts/01-k8s/node-init.sh)
# ============================================================
K8S_VERSION=1.31
K8S_PKG_VERSION=1.31.0
NODE_IP=10.10.0.10
POD_CIDR=10.244.0.0/16
SERVICE_CIDR=10.96.0.0/12

# ============================================================
# etcd 备份恢复 (scripts/01-k8s/etcd-backup.sh, etcd-restore.sh)
# ============================================================
ETCD_ENDPOINT=https://127.0.0.1:2379
ETCD_CACERT=/etc/kubernetes/pki/etcd/ca.crt
ETCD_CERT=/etc/kubernetes/pki/etcd/server.crt
ETCD_KEY=/etc/kubernetes/pki/etcd/server.key
ETCD_CLUSTER=etcd-0=https://127.0.0.1:2380

# ============================================================
# MySQL (scripts/05-mysql/mysql-cluster-deploy.sh, mysql-backup.sh, pitr-restore.sh)
# ============================================================
MYSQL_ROOT_PASSWORD=changeme
MYSQL_REPL_PASSWORD=changeme
MYSQL_APP_PASSWORD=changeme
MYSQL_BACKUP_PASSWORD=changeme
APP_USER_PASSWORD=changeme

# MySQL 集群部署
MYSQL_VERSION=8.4.4
MYSQL_NODES="10.10.30.11 10.10.30.12 10.10.30.13"
INNODB_BUFFER_POOL=48G

# MySQL 备份
MYSQL_USER=backup
MYSQL_PASS=changeme
MYSQL_BACKUP_DIR=/data/mysql-backup
MYSQL_KEEP_DAYS=30
MYSQL_BINLOG_DIR=/data/mysql-backup/binlog

# ============================================================
# Redis (scripts/06-redis/redis-cluster-deploy.sh, redis-backup.sh)
# ============================================================
REDIS_PASSWORD=changeme
REDIS_NODES="10.10.40.11 10.10.40.12 10.10.40.13 10.10.40.14 10.10.40.15 10.10.40.16"
REDIS_USER=redis
REDIS_PORT=6379
REDIS_VERSION=8.6.3
REDIS_MAXMEMORY=12gb
REDIS_BACKUP_DIR=/data/redis-backup
REDIS_BACKUP_KEEP_DAYS=7

# ============================================================
# Elasticsearch / ELK (scripts/04-elk/elk-deploy.sh, elk-check.sh)
# ============================================================
ES_VERSION=8.11.3
ES_PASSWORD=changeme
ES_HOST=localhost:9200
ES_JVM_XMS=16g
ES_JVM_XMX=16g
ELK_NAMESPACE=logging

# ============================================================
# Harbor (scripts/01-k8s/harbor-deploy.sh, harbor-ha.sh)
# ============================================================
HARBOR_HOST=harbor.example.com
HARBOR_HOSTNAME=harbor.example.com
HARBOR_ADMIN_PASSWORD=changeme
HARBOR_DB_PASSWORD=changeme
HARBOR_VERSION=2.12.0

# Harbor HA 节点配置
HARBOR_MASTER_NODES="10.10.10.31"
HARBOR_BACKUP_NODES="10.10.10.32"
HARBOR_LOAD_BALANCER=10.10.10.30

# Harbor 外部 PostgreSQL
PG_HOST=10.10.20.10
PG_PORT=5432
PG_ADMIN_USER=postgres
PG_ADMIN_PASS=changeme

# Harbor 外部 Redis (HA模式)
REDIS_HOST=10.10.40.11

# Harbor OSS/S3 存储
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=harbor-registry
OSS_ACCESS_KEY=changeme
OSS_SECRET_KEY=changeme

# ============================================================
# Nginx + Keepalived (scripts/07-nginx/nginx-ha-deploy.sh, nginx-check.sh)
# ============================================================
NGINX_VIP=10.10.50.100
NGINX_NODES="10.10.50.11 10.10.50.12"
NGINX_REAL_SERVERS="10.10.50.11 10.10.50.12 10.10.50.13"
KEEPALIVED_ROUTER_ID=51
KEEPALIVED_INTERFACE=eth0
KEEPALIVED_VIRTUAL_IP=10.10.50.100
KEEPALIVED_AUTH_PASS=CHANGEME
KEEPALIVED_PASS=CHANGEME

# ============================================================
# CI/CD (scripts/02-cicd/cicd-deploy.sh)
# ============================================================
JENKINS_URL=http://jenkins:8080
SONARQUBE_URL=http://sonarqube:9000
ARGOCD_URL=http://argocd-server:80
CICD_NAMESPACE=cicd
DOCKER_REGISTRY=harbor.example.com
DOCKER_NAMESPACE=library
SONAR_DB_PASS=changeme

# ============================================================
# Gateway / 微服务网关 (scripts/09-gateway/gateway-deploy.sh)
# ============================================================
ISTIO_VERSION=1.20.0

# ============================================================
# Ansible (scripts/08-ansible/ansible-deploy.sh)
# === 证书管理 ===
CERT_MANAGER_ENABLED=true
CERT_DURATION=8760h
CERT_RENEW_BEFORE=720h
CERT_ISSUER_NAME=letsencrypt-prod
CERT_ISSUER_EMAIL=admin@example.com

# === Ansible ===
ANSIBLE_VAULT_PASSWORD=changeme
ANSIBLE_FORKS=20
ANSIBLE_TIMEOUT=30

# ============================================================
# 监控告警 (scripts/03-monitor/monitor-deploy.sh, monitor-check.sh)
# ============================================================
MONITOR_NAMESPACE=monitoring
PROMETHEUS_RETENTION=30d
PROMETHEUS_URL=localhost:9090
ALERTMANAGER_URL=alertmanager:9093
STORAGE_CLASS=alicloud-disk-ssd

# ============================================================
# SMTP (邮件告警)
# ============================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=alert@example.com
SMTP_PASSWORD=changeme

# ============================================================
# 安全加固 (scripts/10-security/security-harden.sh)
# ============================================================
SSH_PORT=22
ADMIN_IP=10.10.0.1
SECURITY_NODES=""
