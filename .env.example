# 企业级运维项目集 - 环境变量模板
# 复制为 .env 并填入实际值: cp .env.example .env

# === 通用 ===
ENVIRONMENT=production
LOG_LEVEL=info

# === K8s ===
K8S_VERSION=1.28
NODE_IP=10.10.0.10
POD_CIDR=10.244.0.0/16
SERVICE_CIDR=10.96.0.0/12

# === MySQL ===
MYSQL_ROOT_PASSWORD=changeme
MYSQL_REPL_PASSWORD=changeme
MYSQL_BACKUP_PASSWORD=changeme
APP_USER_PASSWORD=changeme

# === Redis ===
REDIS_PASSWORD=changeme
REDIS_NODES="10.10.40.11 10.10.40.12 10.10.40.13 10.10.40.14 10.10.40.15 10.10.40.16"

# === Elasticsearch ===
ES_JVM_XMS=16g
ES_JVM_XMX=16g
ADMIN_PASSWORD=changeme

# === Harbor ===
HARBOR_HOST=harbor.example.com
HARBOR_ADMIN_PASSWORD=changeme
HARBOR_DB_PASSWORD=changeme

# === Keepalived ===
KEEPALIVED_AUTH_PASS=CHANGEME

# === SMTP ===
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=alert@example.com
SMTP_PASSWORD=changeme

# === Prometheus ===
PROMETHEUS_RETENTION=30d

# === Ansible ===
ANSIBLE_VAULT_PASSWORD=changeme
