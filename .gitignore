# .gitignore - 企业级运维项目集

# 环境变量文件
.env
.env.*
!.env.example
*.env

# 密钥文件
*.pem
*.key
*.crt
*.p12
id_rsa*
*.jks

# Terraform
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
crash.log
crash.*.log

# Ansible
*.retry
.vault_pass

# 日志
*.log
logs/

# 临时文件
*.tmp
*.swp
*~
.DS_Store
Thumbs.db

# 编辑器
.vscode/
.idea/

# 备份
*.bak
*.backup
